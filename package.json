{
  "name": "@alignex/offline-candidate-browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "description": "AlignEx secure CBT client app for offline examination delivery.",
  "author": "AlignEx",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5175",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5175 tsx electron/main.ts",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "start": "electron dist/electron/main.js",
    "dist": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.alignex.client-app",
    "productName": "AlignEx Client App",
    "extraMetadata": {
      "name": "alignex-client-app"
    },
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/images/logo.ico",
      "artifactName": "AlignEx-Client-App-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AlignEx Client App",
      "installerIcon": "public/images/logo.ico",
      "uninstallerIcon": "public/images/logo.ico"
    }
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
